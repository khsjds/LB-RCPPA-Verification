theory ARPKIvfinalTests begin

/*
 * Facts that start with 'F_' are given priority by the heuristic.
 * Effectively, the below definitions prioritize some prefix-unrolling
 * of the rules, similar to the way in which Scyther handles
 * prefix-closed role instances.
 *
 */
#define DomainHasARPKICertA(a,b,c) F_DomainHasARPKICertA(a,b,c)
// for coloration purposes
#define Generate_Keypair_trusted Generate_Keypair_trusted_COLOR00F_x
#define Generate_Keypair_untrusted Generate_Keypair_untrusted_COLORF00_x

#include "arpki.spthypp"

//=========================================================================
// Sanity checks - existence lemmas!
//=========================================================================

//[auto-proved]
lemma test:
  exists-trace
  " Ex #i. ExecutionTestComplete() @i"

//[auto-proved]
lemma test2arg:
  exists-trace
  " Ex #i #j x. ExecutionTestCompleteARG(x) @i
            & ExecutionTestComplete2ARG(x) @j"

//[auto-proved]
lemma can_accept_connection:
   exists-trace
   " (Ex cid b a reason key #i. ConnectionAccepted(cid,b,a,reason,key)@i 
                              & (not (Ex #j. KU(key) @j)) ) " //this second condition is needed to stop the automatic search from finding a non-sensical trace based on the attacker having generated all fresh things - this extra condition may not be necessary if we put additional checks into the accepting rule.



//=========================================================================
// Security properties
//=========================================================================

//[auto-proved]
lemma private_key_secrecy:
  " not Ex a k #i #j. ( GEN_LTK(a,k, 'trusted')@i & K(k)@j ) "

//[auto-proved]
lemma cert_accepted_has_been_requested:
   "( All a key #i. ReceivedARPKICert(a,key)@i 
      ==> Ex #j. AskedForARPKICert(a,key)@j & j < i
    )"

//[auto-proved]
lemma cert_logged_has_been_accepted:
   "( All a key #i. LoggedARPKICert(a,key)@i 
      ==> Ex #j. ReceivedARPKICert(a,key)@j & j < i
    )"

//[auto-proved]
lemma connection_accepted:
   " ( 
       All cid a b reason key  #i1  .  
         ( ConnectionAccepted(cid,b,a,reason,key)@i1
         )
         ==>
         ( (Ex #j . AcceptedARPKICert(a,key)@j) 
         | (Ex #j . LoggedARPKICert(a,key)@j)
         )
     ) "

end


/*
==============================================================================
summary of summaries:

