// Verify period/key uniqueness between vehicle and RSU
lemma P2_session_period_uniqueness:
    "All ppid rsu_id ki1 ki2 dp #i #j.
        SessionComplete(ppid, rsu_id, ki1, dp) @ i &
        SessionComplete(ppid, rsu_id, ki2, dp) @ j 
    ==> ki1 = ki2 & #i = #j"
lemma P2_session_key_uniqueness:
    "All ppid rsu_id ki dp1 dp2 #i #j.
        SessionComplete(ppid, rsu_id, ki, dp1) @ i &
        SessionComplete(ppid, rsu_id, ki, dp2) @ j 
    ==> dp1 = dp2 & #i = #j"
        
// Verify authentication of both parties
lemma P2_mutual_authentication:
    "All ppid rsu_id ki dp #i.
        SessionComplete(ppid, rsu_id, ki, dp) @ i
    ==> (Ex rta vid sv2 pv2 #j #j1 #j2.             // Vehicle authentication
            SetupComplete(rta, vid, ppid) @ j &     // Link vid to ppid through SetupComplete
            HasKEKeys(ppid, sv2, pv2) @ j1 &        // Check vehicle has valid KE keys
            VehicleKeyGen(ppid, rsu_id, ki) @ j2 &  // Vehicle completes key computation
            j < j1 & j1 < j2 & j2 < i) &
        (Ex rtu_id pk_rsu #k1 #k2.                  // RSU authentication  
            SetupRSU(rtu_id, rsu_id, pk_rsu) @ k1 & // Action fact for when RSU keys were established
            RSUKeyGen(ppid, rsu_id, ki) @ k2 &      // RSU completes key computation
            k1 < k2 & k2 < i)"

// Verify time period authorization correctness
lemma P2_time_period_authorization:
    "All ppid rsu_id ki dp #i.
        SessionComplete(ppid, rsu_id, ki, dp) @ i
    ==> (Ex kr #j. AuthPeriod(kr, dp) @ j & j < i & ki = kr)"

// Check signature generation follows protocol order
lemma P3_signature_generation_order:
    "All ppid ring msg sig ts #i.
        MessagePackage(msg, ring, sig, ppid, ts) @ i
    ==> Ex #j. RingInit(ppid) @ j & j < i"

// A signing member must have valid signature keys
lemma P3_ring_member_validity:
    "All ppid ring msg sig ts #i.
        MessagePackage(msg, ring, sig, ppid, ts) @ i
    ==> Ex rta vid sv1 pv1 dv #j.
            (SetupComplete(rta, vid, ppid) @j &
            HasSignatureKeys(ppid, sv1, pv1, dv) @ j) &
            j < i"

// A signer must have valid session (ki and dp)
lemma P3_signer_authorization:
    "All ppid ring msg sig ts #i.
        MessagePackage(msg, ring, sig, ppid, ts) @ i
    ==> Ex rsu_id ki dp #j.
            SessionComplete(ppid, rsu_id, ki, dp) @ j &
            j < i"

// Verify message binding through mu
lemma P3_message_binding:
    "All mu mpk_sig sum_pv11 sum_pv12 msg1 msg2 y1 y2 #i #j.
        MuConstruction(mu, mpk_sig, sum_pv11, msg1, y1) @ i &
        MuConstruction(mu, mpk_sig, sum_pv12, msg2, y2) @ j
    ==> sum_pv11 = sum_pv12 & msg1 = msg2 & y1 = y2 & #i = #j"

// Verify signer's private key binding through Z
lemma P3_signer_binding:
    "All Z sv1 sv2 mu1 mu2 R1 R2 y1 y2 b1 b2 #i #j.
        ZConstruction(Z, sv1, mu1, R1, y1, b1) @ i &
        ZConstruction(Z, sv2, mu2, R2, y2, b2) @ j
    ==> sv1 = sv2 & mu1 = mu2 & R1 = R2 & y1 = y2 & b1 = b2 & #i = #j &
        (Ex mpk_sig sum_pv msg #k. MuConstruction(mu1, mpk_sig, sum_pv, msg, y1) @ k & #k = #i)" 

// Verify binding to pseudo-identity through K
lemma P3_identity_binding:
    "All Kv ppid1 ppid2 pv1 pv2 R1 R2 #i #j.
        KConstruction(Kv, ppid1, pv1, R1) @ i &
        KConstruction(Kv, ppid2, pv2, R2) @ j
    ==> ppid1 = ppid2 & pv1 = pv2 & R1 = R2 & #i = #j"

// Verify binding component uniqueness
lemma P3_binding_uniqueness:
    "All B dv1 dv2 ppid1 ppid2 ts1 ts2 #i #j.
        BConstruction(B, dv1, ppid1, ts1) @ i &
        BConstruction(B, dv2, ppid2, ts2) @ j
    ==> dv1 = dv2 & ppid1 = ppid2 & ts1 = ts2 & #i = #j"


    lemma P4_verification_ordering:
    "All ppid msg ring_pairs ts #i.
        MessageAuthenticated(ppid, msg, ring_pairs, ts) @ i
    ==> Ex rsu_id Z Kv mu B #j #k.
            MessageCreated(rsu_id, <msg, ring_pairs, <Z, Kv, mu, B>, ppid, ts>) @ j &
            VerifySignature(ppid, msg, Z, Kv, mu) @ k &
            VerifyBinding(ppid, msg, B, ts) @ k &
            j < k & k < i"

lemma P4_message_reception:
    "All ppid_r rsu_id msg_package #i.
        ReceiveMessage(ppid_r, rsu_id, msg_package) @ i
    ==> (Ex #j. MessageCreated(rsu_id, msg_package) @ j & j < i) &
        (Ex rta vid dp ki #k1 #k2.
            SetupComplete(rta, vid, ppid_r) @ k1 &
            SessionComplete(ppid_r, rsu_id, ki, dp) @ k2 &
            k1 < k2 & k2 < i)"

lemma P4_authentication_soundness:
    "All ppid msg ring_pairs ts #i.
        MessageAuthenticated(ppid, msg, ring_pairs, ts) @ i
    ==> (Ex rsu_id Z Kv mu B #j. 
            MessageCreated(rsu_id, <msg, ring_pairs, <Z, Kv, mu, B>, ppid, ts>) @ j & 
            j < i)"

lemma P4_message_freshness:
    "All ppid_r rsu_id msg_package #i.
        ReceiveMessage(ppid_r, rsu_id, msg_package) @ i
    ==> not(Ex #j. ExpireMessage(msg_package) @ j & j < i)"

lemma P4_regional_reception:
    "All ppid_r1 ppid_r2 rsu_id1 rsu_id2 msg_package #i #j.
        ReceiveMessage(ppid_r1, rsu_id1, msg_package) @ i &
        ReceiveMessage(ppid_r2, rsu_id2, msg_package) @ j
    ==> rsu_id1 = rsu_id2"



// Ensure protocol flow
lemma P5_reauth_protocol_flow:
    "All vid ppid rta_old rta_new #i.
        ReauthComplete(vid, ppid, rta_old, rta_new) @ i
    ==> ((Ex #j #k #l.
            ReauthRequest(vid, ppid, rta_old, rta_new) @ j &
            ReauthForward(rta_new, vid) @ k &
            ProcessFound(rta_new, rta_old, vid) @ l &
            j < k & k < l & l < i) |
         (Ex #j #k #l.
            ReauthRequest(vid, ppid, rta_old, rta_new) @ j &
            ReauthForward(rta_new, vid) @ k &
            NoValidML(rta_new, vid) @ l &
            j < k & k < l & l < i))"

// Make sure the transfered and expired ML is consistent
lemma P5_reauth_ml_consistency:
    "All vid ppid rta_old rta_new #i.
        ReauthComplete(vid, ppid, rta_old, rta_new) @ i
    ==> (Ex #j #k.
            FoundInML(rta_old, vid) @ j &
            TransferML(rta_old, rta_new, vid) @ k &
            j < k & k < i)"

// Ensure the credential is preserved after reauthentication
lemma P5_reauth_credential_preservation:
    "All vid ppid rta_old rta_new #i.
        ReauthComplete(vid, ppid, rta_old, rta_new) @ i
    ==> (Ex vp_old kk_old vp_new kk_new #j #k #l.
            RegisterVehicle(rta_old, vid, ppid, vp_old, kk_old) @ j &
            TransferML(rta_old, rta_new, vid) @ k &
            RegisterVehicle(rta_new, vid, ppid, vp_new, kk_new) @ l &
            j < k & k < l & l < i)"

// The vehicle can only reauth with a RTA at a time
lemma P5_reauth_state_uniqueness:
    "All vid ppid rta_old1 rta_old2 rta_new1 rta_new2 #i #j.
        ReauthRequest(vid, ppid, rta_old1, rta_new1) @ i &
        ReauthRequest(vid, ppid, rta_old2, rta_new2) @ j &
        i < j
    ==> Ex #k. ReauthComplete(vid, ppid, rta_old1, rta_new1) @ k &
            i < k & k < j"

